# ── IoBuild — Variables de Entorno ──
#
# Instrucciones:
#   1. Copia este archivo a .env:   cp .env.example .env
#   2. Edita .env con tus credenciales reales (DB, JWT, Stripe)
#   3. NUNCA subas .env al repositorio (ya está en .gitignore)
#
# ──────────────────────────────────────────────────

# ── MySQL ──
DB_HOST=a
DB_PORT=b
DB_USER=c
DB_PASSWORD=d

# ── JWT Secret (mínimo 32 caracteres) ──
JWT_SECRET=iobuild-super-secret-key-minimum-32-chars!!-dev

# ── InfluxDB (telemetría IoT) ──
INFLUXDB_TOKEN=iobuild-telemetry-token-dev
INFLUXDB_PASSWORD=admin123

# ── MQTT (broker de mensajería IoT) ──
MQTT_HOST=mosquitto
MQTT_PORT=1883

# ── Stripe (opcional, para suscripciones y pagos) ──
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
