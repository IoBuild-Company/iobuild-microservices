{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "TokenSettings": {
    "Secret": "dev-fallback-key-minimum-32-characters!!"
  },
  "InfluxDb": {
    "Host": "influxdb",
    "Port": 8086,
    "Token": "iobuild-telemetry-token-dev",
    "Org": "iobuild",
    "Bucket": "iobuild-telemetry"
  },
  "Mqtt": {
    "Host": "mosquitto",
    "Port": 1883,
    "Topic": "telemetry/#",
    "ClientId": "iobuild-telemetry-worker"
  },
  "ConnectionStrings": {
    "DefaultConnection": "server=localhost;port=3306;database=iobuild_devices;user=root;password=;"
  }
}
