{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Yarp": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ReverseProxy": {
    "Routes": {
      "iam-auth": {
        "ClusterId": "iam-cluster",
        "Match": {
          "Path": "/api/v1/authentication/{**catch-all}"
        }
      },
      "iam-users": {
        "ClusterId": "iam-cluster",
        "Match": {
          "Path": "/api/v1/users/{**catch-all}"
        }
      },
      "iam-profiles": {
        "ClusterId": "iam-cluster",
        "Match": {
          "Path": "/api/v1/profiles/{**catch-all}"
        }
      },
      "devices-all": {
        "ClusterId": "devices-cluster",
        "Match": {
          "Path": "/api/v1/devices/{**catch-all}"
        }
      },
      "projects-all": {
        "ClusterId": "projects-cluster",
        "Match": {
          "Path": "/api/v1/projects/{**catch-all}"
        }
      },
      "units-all": {
        "ClusterId": "projects-cluster",
        "Match": {
          "Path": "/api/v1/units/{**catch-all}"
        }
      },
      "clients-all": {
        "ClusterId": "projects-cluster",
        "Match": {
          "Path": "/api/v1/clients/{**catch-all}"
        }
      },
      "subscriptions-all": {
        "ClusterId": "subscriptions-cluster",
        "Match": {
          "Path": "/api/v1/subscriptions/{**catch-all}"
        }
      },
      "plans-all": {
        "ClusterId": "subscriptions-cluster",
        "Match": {
          "Path": "/api/v1/plans/{**catch-all}"
        }
      },
      "analytics-all": {
        "ClusterId": "analytics-cluster",
        "Match": {
          "Path": "/api/v1/analytics/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "iam-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "Destinations": {
          "iam-destination": {
            "Address": "http://localhost:5001/"
          }
        },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:10",
            "Timeout": "00:00:05",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        }
      },
      "devices-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "Destinations": {
          "devices-destination": {
            "Address": "http://localhost:5002/"
          }
        },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:10",
            "Timeout": "00:00:05",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        }
      },
      "projects-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "Destinations": {
          "projects-destination": {
            "Address": "http://localhost:5003/"
          }
        },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:10",
            "Timeout": "00:00:05",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        }
      },
      "subscriptions-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "Destinations": {
          "subscriptions-destination": {
            "Address": "http://localhost:5004/"
          }
        },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:10",
            "Timeout": "00:00:05",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        }
      },
      "analytics-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "Destinations": {
          "analytics-destination": {
            "Address": "http://localhost:5005/"
          }
        },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:10",
            "Timeout": "00:00:05",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        }
      }
    }
  }
}
